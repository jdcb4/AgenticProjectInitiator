services:
  app:
    build: .
    image: {{docker_namespace}}/{{project_slug}}:latest
    ports:
      - "3000:3000"
    environment:
      NODE_ENV: production
      PORT: 3000
      LOG_LEVEL: info
      CORS_ORIGIN: http://localhost:3000

