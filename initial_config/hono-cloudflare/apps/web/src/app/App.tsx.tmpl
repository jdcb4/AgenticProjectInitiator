import { useQuery } from "@tanstack/react-query";
import { HealthResponseSchema } from "@{{project_slug}}/shared/schemas";

import { Body, Caption, Heading } from "@/components/ui/typography";
import { Stack, Surface } from "@/components/ui/surface";

export function App() {
  const { data, isLoading, isError } = useQuery({
    queryKey: ["health"],
    queryFn: async () => {
      const res = await fetch("/api/health");
      const json = await res.json();
      return HealthResponseSchema.parse(json);
    },
  });

  return (
    <Surface
      as="main"
      className="min-h-dvh flex flex-col items-center justify-center px-6"
    >
      <Stack gap="default" align="center" className="text-center max-w-prose">
        <Heading level={1}>{{project_name}}</Heading>
        <Body className="text-text-secondary">
          Scaffolded from the Hono on Cloudflare preset.
        </Body>
        <Caption>
          API:{" "}
          {isLoading
            ? "checking…"
            : isError
              ? "unreachable"
              : `ok (${data?.timestamp})`}
        </Caption>
      </Stack>
    </Surface>
  );
}
